{
  "name": "zotero-pdf-hand-catcher",
  "version": "0.2.1",
  "description": "A Zotero plugin that finds items without PDFs, opens each in an isolated Edge browser, and auto-captures downloads back into Zotero.",
  "type": "module",
  "keywords": [
    "zotero",
    "pdf",
    "edge",
    "plugin",
    "reference-manager"
  ],
  "config": {
    "addonName": "Zotero PDF Hand Catcher",
    "addonID": "pdfhandcatcher@qifu04",
    "addonRef": "pdfhandcatcher",
    "addonInstance": "PDFHandCatcher",
    "prefsPrefix": "extensions.zotero.pdfhandcatcher"
  },
  "main": "src/index.ts",
  "scripts": {
    "start": "zotero-plugin serve",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && zotero-plugin build",
    "lint": "prettier --write . && eslint . --ext .ts --fix",
    "release": "zotero-plugin release",
    "test": "jest --passWithNoTests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qifu04/zotero-pdf-hand-catcher.git"
  },
  "author": "qifu04",
  "license": "AGPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/qifu04/zotero-pdf-hand-catcher/issues"
  },
  "homepage": "https://github.com/qifu04/zotero-pdf-hand-catcher",
  "dependencies": {
    "zotero-plugin-toolkit": "^5.0.1"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@types/node": "^25.0.10",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "fake-indexeddb": "^6.2.5",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "zotero-plugin-scaffold": "^0.8.2",
    "zotero-types": "^4.0.5"
  },
  "prettier": {
    "printWidth": 120,
    "tabWidth": 2,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": [
          "*.xhtml"
        ],
        "options": {
          "htmlWhitespaceSensitivity": "css"
        }
      }
    ]
  }
}
